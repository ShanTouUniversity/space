---
const { currentPath = "/" } = Astro.props;

const isCurrent = (href: string) =>
  href === "/" ? currentPath === href : currentPath.startsWith(href);
---

<div class="nav-links">
  <a href="/" aria-current={isCurrent("/") ? "page" : null}>首页</a>
  <a href="/blog" aria-current={isCurrent("/blog") ? "page" : null}>博客</a>
  <a href="/tags" aria-current={isCurrent("/tags") ? "page" : null}>标签</a>
  <a href="/about" aria-current={isCurrent("/about") ? "page" : null}>关于</a>
  <a href="/graffiti" aria-current={isCurrent("/graffiti") ? "page" : null}>涂鸦</a>
  <span class="nav-sep">|</span>
  <a href="https://nav.shantou.university" target="_blank" rel="noopener noreferrer" class="external-link">导航</a>
  <a href="https://news.shantou.university" target="_blank" rel="noopener noreferrer" class="external-link">资讯</a>
  <a href="https://voice.shantou.university" target="_blank" rel="noopener noreferrer" class="external-link">Voice</a>
  <a href="https://shantou.university" target="_blank" rel="noopener noreferrer" class="external-link">博客</a>
</div>