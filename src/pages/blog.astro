---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPost from "../components/BlogPost.astro";


const top_n = 15;

const allPosts = (
  await Astro.glob("../pages/posts/**/*.{md,markdown,mdown,mkd,mdwn,mdx}")
)
  .sort((a, b) => {
    let aData = new Date(a.frontmatter.pubDate).getTime();
    let bData = new Date(b.frontmatter.pubDate).getTime();
    return bData - aData;
  })
  .slice(0, top_n);

const pageTitle = "博客";
---

<BaseLayout pageTitle={pageTitle} description="ST.U Space 的博客，包含技术、开源、社区教育等内容。">
  <ul>
    {
      allPosts.map((post) => (
        <BlogPost
          url={post.url}
          title={post.frontmatter.title}
          date={post.frontmatter.pubDate}
          description={post.frontmatter.description}
        />
      ))
    }
  </ul>
</BaseLayout>
